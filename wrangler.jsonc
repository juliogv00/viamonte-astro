{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "viamonte-psicologia",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"pages_build_output_dir": "./dist/client",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "viamonte-psicologia",
			"database_id": "c7419735-89be-496a-9047-a2b7a08e1ad1"
		}
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "viamonte-media"
		}
	]
}
