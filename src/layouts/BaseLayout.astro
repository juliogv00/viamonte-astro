---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Carmen Viamonte | Psicología y Psicoanálisis en Madrid",
  description = "Consulta de psicología y psicoterapia en Madrid Chamberí con Carmen Viamonte. Orientación psicoanalítica. Sesiones presenciales y online. Español e inglés.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Parkinsans:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script src="https://unpkg.com/lucide@latest" is:inline></script>

    <style is:global>
      body {
        background-color: #eee5db;
        color: #553527;
        -webkit-font-smoothing: antialiased;
      }

      .hover-card {
        transition: transform 0.5s cubic-bezier(0.25, 0.8, 0.25, 1),
          box-shadow 0.5s cubic-bezier(0.25, 0.8, 0.25, 1);
      }
      .hover-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(85, 53, 39, 0.12);
      }

      details > summary { list-style: none; }
      details > summary::-webkit-details-marker { display: none; }
      details[open] summary ~ * {
        animation: sweep 0.4s ease-in-out forwards;
      }
      @keyframes sweep {
        0%   { opacity: 0; transform: translateY(-5px); }
        100% { opacity: 1; transform: translateY(0); }
      }

      .modal-backdrop { backdrop-filter: blur(8px); }

      #mobile-menu {
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
      }

      #noise-overlay {
        position: fixed; inset: 0;
        z-index: 9998; pointer-events: none;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 180px 180px;
        mix-blend-mode: overlay;
      }

      #page-transition {
        position: fixed; inset: 0;
        z-index: 99999; background: #553527;
        transform: scaleY(0); transform-origin: bottom;
        pointer-events: none;
      }

      @media (hover: hover) and (pointer: fine) {
        * { cursor: none !important; }
      }
      #cursor-dot {
        position: fixed; top: 0; left: 0;
        width: 7px; height: 7px; border-radius: 50%;
        background: #553527;
        pointer-events: none; z-index: 10000;
        will-change: transform;
        transform: translate(-50%, -50%);
        transition: width 0.2s ease, height 0.2s ease, opacity 0.2s ease;
      }
      #cursor-ring {
        position: fixed; top: 0; left: 0;
        width: 32px; height: 32px; border-radius: 50%;
        border: 1.5px solid #553527;
        opacity: 0.35;
        pointer-events: none; z-index: 9999;
        will-change: transform;
        transform: translate(-50%, -50%);
        transition: width 0.25s ease, height 0.25s ease, opacity 0.25s ease;
      }
      #cursor-dot.is-hovering  { width: 5px; height: 5px; opacity: 0.6; }
      #cursor-ring.is-hovering { width: 44px; height: 44px; opacity: 0.2; }
      #cursor-dot.is-clicking  { width: 9px; height: 9px; }
      #cursor-ring.is-clicking { width: 26px; height: 26px; opacity: 0.5; }
      #cursor-dot.on-dark  { background: #eee5db; }
      #cursor-ring.on-dark { border-color: #eee5db; }

      [data-split-words], [data-split-lines] { visibility: hidden; }
      [data-hero-svg] path { stroke-dasharray: 300; stroke-dashoffset: 300; }

      .area-tag {
        transition: background 0.25s, color 0.25s, border-color 0.25s;
      }
      .area-tag:hover {
        background: #3b6544;
        color: #eee5db;
        border-color: #3b6544;
      }
    </style>
  </head>
  <body class="font-body overflow-x-hidden">

    <div id="noise-overlay" aria-hidden="true"></div>
    <div id="page-transition" aria-hidden="true"></div>

    <slot />

    <script>
      import "../scripts/lenis.js";
      import { initUI } from "../scripts/ui.js";
      import { initAnimations } from "../scripts/animations.js";
      import { initCursor } from "../scripts/cursor.js";

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // @ts-ignore
      if (typeof lucide !== "undefined") lucide.createIcons();

      initUI();

      if (!prefersReduced) {
        initAnimations();
        initCursor();
        initHeroParallax();
      }

      function initHeroParallax() {
        const heroSection   = document.getElementById('hero-section');
        const floatingImages = document.getElementById('floating-images');
        if (!heroSection || !floatingImages) return;

        const images = floatingImages.querySelectorAll('[data-hero-img]');
        if (images.length === 0) return;

        const elementsMap = new Map();
        images.forEach((img) => {
          const depth = parseFloat(img.dataset.depth) || 1;
          elementsMap.set(img, { depth, currentPosition: { x: 0, y: 0 } });
        });

        const sensitivity = 0.5;
        const easingFactor = 0.08;
        const mousePosition = { x: 0, y: 0 };

        function updateMousePosition(e) {
          const rect = heroSection.getBoundingClientRect();
          if (rect.bottom < 0) return; // hero off screen
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          mousePosition.x = (e.clientX - centerX) / (rect.width / 2);
          mousePosition.y = (e.clientY - centerY) / (rect.height / 2);
        }

        window.addEventListener('mousemove', updateMousePosition);

        function animate() {
          elementsMap.forEach((data, el) => {
            const strength = data.depth * sensitivity;
            const targetX = mousePosition.x * strength * 30;
            const targetY = mousePosition.y * strength * 30;
            data.currentPosition.x += (targetX - data.currentPosition.x) * easingFactor;
            data.currentPosition.y += (targetY - data.currentPosition.y) * easingFactor;
            el.style.transform = `translate3d(${data.currentPosition.x}px, ${data.currentPosition.y}px, 0)`;
          });
          requestAnimationFrame(animate);
        }

        animate();
      }
    </script>
  </body>
</html>
