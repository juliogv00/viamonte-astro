---
---

<section id="areas" class="py-16 md:py-24 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-10 md:mb-14">
      <span class="text-forest font-bold uppercase tracking-widest text-xs mb-3 block">Especialidades</span>
      <h2 class="font-display text-4xl lg:text-5xl font-bold text-main tracking-tight">Áreas de trabajo.</h2>
    </div>

    <!-- Desktop: todas visibles -->
    <div data-stagger class="hidden md:flex flex-wrap gap-2.5 md:gap-3" role="list" aria-label="Áreas de especialidad">
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Duelo y pérdidas</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Procesos migratorios</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Ansiedad y angustia</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Tristeza y estados depresivos</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Pensamientos recurrentes u obsesivos</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Cambios de etapa vital</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Separaciones y rupturas</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Fobias</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Conflictos familiares</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Problemas de pareja</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Sexualidad</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Identidad de género y orientación sexual</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Autoestima</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Sentimientos de vacío o falta de sentido</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Dificultad en la toma de decisiones</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Procesos de adopción</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Soledad o dificultad para vincularse</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Culpa, vergüenza o malestar difuso</span>
      <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Dificultades en la regulación emocional</span>
    </div>

    <!-- Mobile: primeras 8 + colapso -->
    <div class="md:hidden">
      <div class="flex flex-wrap gap-2" role="list" aria-label="Áreas de especialidad (principales)">
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Duelo y pérdidas</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Procesos migratorios</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Ansiedad y angustia</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Tristeza y estados depresivos</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Cambios de etapa vital</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Separaciones y rupturas</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Conflictos familiares</span>
        <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Autoestima</span>
      </div>

      <div
        id="areas-extra"
        class="overflow-hidden transition-all duration-500 ease-in-out"
        style="max-height:0"
        aria-hidden="true"
      >
        <div class="flex flex-wrap gap-2 pt-2" role="list" aria-label="Áreas de especialidad (adicionales)">
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Pensamientos recurrentes u obsesivos</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Fobias</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Problemas de pareja</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Sexualidad</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Identidad de género y orientación sexual</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Sentimientos de vacío o falta de sentido</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Dificultad en la toma de decisiones</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Procesos de adopción</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Soledad o dificultad para vincularse</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Culpa, vergüenza o malestar difuso</span>
          <span role="listitem" class="area-tag border border-main/25 text-main text-sm font-medium px-4 py-2 rounded-full">Dificultades en la regulación emocional</span>
        </div>
      </div>

      <button
        id="areas-toggle"
        aria-expanded="false"
        aria-controls="areas-extra"
        class="mt-5 inline-flex items-center gap-2 text-main font-semibold text-sm border-b border-main/30 pb-0.5 hover:border-main transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-main rounded-sm"
      >
        <span id="areas-toggle-label">Ver todas las áreas</span>
        <i data-lucide="chevron-down" id="areas-toggle-icon" class="w-4 h-4 transition-transform duration-300" aria-hidden="true"></i>
      </button>
    </div>

  </div>
</section>

<script>
  const extra  = document.getElementById('areas-extra');
  const btn    = document.getElementById('areas-toggle');
  const label  = document.getElementById('areas-toggle-label');
  const icon   = document.getElementById('areas-toggle-icon');
  let open = false;

  btn?.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));
    if (extra) {
      extra.style.maxHeight = open ? extra.scrollHeight + 'px' : '0';
      extra.setAttribute('aria-hidden', String(!open));
    }
    if (label) label.textContent = open ? 'Ver menos' : 'Ver todas las áreas';
    if (icon)  icon.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
  });
</script>
