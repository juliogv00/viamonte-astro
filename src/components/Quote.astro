---
---

<section data-section="quote" class="relative px-8 overflow-hidden min-h-[70vh] flex items-center py-32 md:py-48">
  <!-- Imagen de fondo -->
  <div class="absolute inset-0" aria-hidden="true">
    <img src="/images/blog-lake.jpeg" alt="" class="w-full h-full object-cover object-center">
    <div class="absolute inset-0 bg-gradient-to-b from-main/20 via-main/40 to-main/20"></div>
  </div>

  <!-- Frame superior -->
  <div class="absolute top-0 left-0 right-0 h-16 bg-[#EEE5DB] rounded-b-[2rem] pointer-events-none z-10 shadow-[0_8px_32px_8px_rgba(85,53,39,0.18)]" aria-hidden="true"></div>

  <!-- Frame inferior -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-[#EEE5DB] rounded-t-[2rem] pointer-events-none z-10" aria-hidden="true"></div>

  <!-- Contenido -->
  <div class="relative max-w-4xl mx-auto text-center">
    <svg class="w-10 h-10 md:w-12 md:h-12 text-[#EEE5DB]/50 mx-auto mb-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
    <blockquote>
      <p data-fade-up class="font-display text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-medium leading-relaxed text-[#EEE5DB] mb-10 md:mb-12">
        "El objetivo del psicoanálisis es que la persona pueda tomar decisiones siendo consciente de ellas, desde la mayor&nbsp;libertad posible."
      </p>
    </blockquote>
  </div>
</section>
