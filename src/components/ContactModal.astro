---
---

<div
  id="contactModal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-heading"
  aria-hidden="true"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-main/50 modal-backdrop" onclick="toggleModal()" aria-hidden="true"></div>

  <!-- Panel -->
  <div class="modal-panel relative z-10 w-full max-w-md bg-[#EEE5DB] rounded-[2rem] shadow-2xl overflow-hidden border border-main/10">

    <div class="flex justify-between items-center px-6 md:px-8 py-5 border-b border-main/10">
      <h2 id="modal-heading" class="font-display font-bold text-xl text-main">Elige forma de contacto</h2>
      <button
        onclick="toggleModal()"
        aria-label="Cerrar"
        class="text-muted hover:text-main transition-colors p-1 rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-main"
      >
        <i data-lucide="x" class="w-5 h-5" aria-hidden="true"></i>
      </button>
    </div>

    <div class="p-6 md:p-8" id="contactOptions">

      <!-- WhatsApp -->
      <a
        href="https://wa.me/34600000000"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full border border-main/30 text-main px-6 py-4 rounded-2xl font-bold text-base hover:bg-main/5 transition-all duration-300 hover:-translate-y-1 mb-4 text-center flex items-center justify-center gap-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-main"
      >
        Contactar por WhatsApp
      </a>

      <!-- Booking -->
      <div id="initialButtons">
        <button
          onclick="showBookingForm()"
          class="w-full bg-forest text-[#EEE5DB] px-6 py-4 rounded-2xl font-bold text-base hover:bg-forest/90 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-forest"
        >
          Agendar sesión
        </button>
        <button
          onclick="toggleFirstTime()"
          class="text-left w-full text-xs text-main/60 hover:text-forest mt-2 underline decoration-dotted focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-main rounded-sm"
        >
          Es mi primera vez
        </button>
      </div>

      <!-- Cal.com embed (hidden by default) -->
      <div id="bookingForm" class="hidden">
        <div id="calEmbedContainer" class="mt-4"></div>
        <button
          type="button"
          onclick="hideBookingForm()"
          class="w-full text-muted text-sm hover:text-main transition-colors mt-4 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-main rounded-sm"
        >
          ← Volver
        </button>
      </div>

      <!-- First time info (hidden by default) -->
      <div id="firstTimeInfo" class="hidden mt-4 p-4 bg-main/5 rounded-xl">
        <p class="text-sm text-muted font-light leading-relaxed">Para tu primera sesión agendaremos una cita donde hablaremos sobre qué te trae aquí y cómo trabajo. Es una oportunidad para conocernos sin ningún compromiso.</p>
      </div>

    </div>
  </div>
</div>

<script is:inline>
  window.Cal = window.Cal || function() { (window.Cal.q = window.Cal.q || []).push(arguments); };
  window.Cal.q = window.Cal.q || [];
</script>
<script src="https://cal.com/embed.js" is:inline async></script>

<style>
  #contactModal.flex { display: flex; }

  .modal-panel {
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease;
  }
  #contactModal.is-open .modal-panel {
    transform: translateY(0);
    opacity: 1;
  }
</style>
