---
---

<section data-hero class="pt-20 md:pt-24 pb-10 md:pb-28 lg:pb-32 px-6 lg:px-12 max-w-7xl mx-auto relative">

  <!-- Imágenes flotantes tablet + desktop -->
  <div class="absolute inset-0 z-0 pointer-events-none hidden md:block opacity-80">
    <div data-hero-img class="absolute top-10 left-0 w-44 h-56 lg:w-64 lg:h-80 rounded-[2rem] overflow-hidden border border-main/10 transform -rotate-6 shadow-soft">
      <img src="/images/hero-dock.jpeg" alt="Espacio tranquilo" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-main/20"></div>
    </div>
    <div data-hero-img class="absolute -top-6 right-6 w-36 h-44 lg:w-48 lg:h-56 rounded-[2rem] overflow-hidden border border-main/10 transform rotate-3 shadow-soft">
      <img src="/images/hero-silhouette.jpeg" alt="Reflexión" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-main/20"></div>
    </div>
    <div data-hero-img class="absolute top-52 right-0 w-40 h-52 lg:w-56 lg:h-72 rounded-[2rem] overflow-hidden border border-main/10 transform -rotate-2 shadow-soft">
      <img src="/images/hero-bridge.jpeg" alt="Perspectiva" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-main/20"></div>
    </div>

    <svg data-hero-svg class="absolute top-20 left-1/4 w-16 h-16 text-accent" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path id="svg-path-1" d="M10,90 Q30,10 50,50 T90,10" />
    </svg>
    <svg data-hero-svg class="absolute bottom-10 right-1/4 w-20 h-20 text-main/20" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path id="svg-path-2" d="M10,50 C30,10 70,10 90,50 C70,90 30,90 10,50 Z" />
    </svg>
  </div>

  <div class="relative z-10 flex flex-col items-center text-center mt-2 md:mt-6 lg:mt-8">
    <h1 data-split-words class="font-display text-4xl sm:text-5xl md:text-[3.75rem] lg:text-[5.5rem] font-bold leading-[1.1] md:leading-[1.05] text-main max-w-5xl mb-10 md:mb-12 tracking-tight relative px-2">
      Un espacio para<br>pararte a pensar.
    </h1>

    <p data-fade-up class="text-base sm:text-lg md:text-xl text-muted max-w-2xl mb-6 md:mb-16 font-light leading-relaxed bg-[#EEE5DB]/60 backdrop-blur-md rounded-2xl p-4 md:p-6">
      A veces algo no encaja, aunque no sepas bien qué es. Trabajo desde una orientación psicoanalítica, acompañando procesos en los que algo necesita ser escuchado, comprendido y elaborado.
    </p>

    <button data-magnetic onclick="toggleModal()" class="w-full sm:w-auto md:hidden bg-forest text-[#EEE5DB] px-8 py-4 rounded-full font-bold text-lg hover:bg-forest/90 shadow-soft">
      Agendar cita
    </button>
  </div>
</section>
