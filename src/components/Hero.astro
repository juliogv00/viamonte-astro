---
---

<section data-hero class="pt-16 md:pt-20 pb-4 md:pb-20 lg:pb-24 relative overflow-hidden min-h-[80vh]" id="hero-section">

  <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10 h-full">

    <!-- Imágenes flotantes con parallax (desktop) -->
    <div class="absolute inset-0 z-0 pointer-events-none hidden lg:block" id="floating-images">
      <div data-hero-img class="absolute left-[2%] -ml-2 w-32 h-26 sm:w-36 sm:h-30 md:w-44 md:h-36 lg:w-54 lg:h-46 rounded-xl overflow-hidden shadow-2xl will-change-transform" data-depth="0.5">
        <img src="/references/IMG_2373.jpeg" alt="" class="w-full h-full object-cover">
      </div>
      <div data-hero-img class="absolute left-[2%] -ml-2 w-34 h-34 sm:w-40 sm:h-40 md:w-50 md:h-50 lg:w-60 lg:h-60 rounded-xl overflow-hidden shadow-2xl -rotate-4 will-change-transform" data-depth="1">
        <img src="/references/75EA9BB3-359E-49B9-B8C0-35CDCC9E1F8C.jpeg" alt="" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-white/20 via-white/10 to-transparent rounded-xl"></div>
      </div>
      <div data-hero-img class="absolute -ml-2 w-44 h-34 sm:w-52 sm:h-42 md:w-62 md:h-52 lg:w-78 lg:h-64 rounded-xl overflow-hidden shadow-2xl -rotate-12 will-change-transform" data-depth="1" style="left: calc(5% - 24px);">
        <img src="/references/IMG_2121.jpeg" alt="" class="w-full h-full object-cover">
      </div>
      <div data-hero-img class="absolute w-34 h-30 sm:w-40 sm:h-34 md:w-50 md:h-44 lg:w-60 lg:h-50 rounded-xl overflow-hidden shadow-2xl rotate-6 will-change-transform" data-depth="2">
        <img src="/references/000043.jpeg" alt="" class="w-full h-full object-cover">
      </div>
      <div data-hero-img class="absolute w-40 h-40 sm:w-48 sm:h-48 md:w-60 md:h-60 lg:w-72 lg:h-72 rounded-xl overflow-hidden shadow-2xl rotate-[19deg] will-change-transform" data-depth="1">
        <img src="/references/IMG_1773.jpeg" alt="" class="w-full h-full object-cover">
      </div>
    </div>

    <div class="relative z-10 flex flex-col items-center text-center mt-8 md:mt-12 lg:mt-14">
      <h1 data-split-words class="font-display text-[2rem] sm:text-5xl md:text-[5rem] lg:text-[6.5rem] font-bold leading-[1.1] md:leading-[1.05] text-main max-w-5xl mb-10 md:mb-12 tracking-tight relative px-2">
        Un espacio para<br>pararte a pensar.
      </h1>

      <p data-fade-up class="text-base sm:text-lg md:text-xl text-muted max-w-2xl mb-12 md:mb-16 font-light leading-relaxed bg-[#EEE5DB]/60 backdrop-blur-md rounded-2xl p-4 md:p-6" style="margin-top: 0;">
        A veces algo no encaja, aunque no sepas bien qué es. Trabajo desde una orientación psicoanalítica, acompañando procesos en los que algo necesita ser escuchado, comprendido y elaborado.
      </p>

      <button data-magnetic onclick="toggleModal()" class="w-full sm:w-auto md:hidden bg-forest text-[#EEE5DB] px-8 py-4 rounded-full font-bold text-lg hover:bg-forest/90 shadow-soft focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-forest">
        Agendar sesión
      </button>
    </div>

  </div>
</section>
