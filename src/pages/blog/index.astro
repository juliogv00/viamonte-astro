---
import { getEmDashCollection, getEntryTerms } from "emdash";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ContactModal from "../../components/ContactModal.astro";

const { entries: posts } = await getEmDashCollection("posts");

const sortedPosts = posts.toSorted((a, b) => {
  const dateA = a.data.publishedAt?.getTime() ?? 0;
  const dateB = b.data.publishedAt?.getTime() ?? 0;
  return dateB - dateA;
});

const postsWithTags = await Promise.all(
  sortedPosts.map(async (post) => {
    const tags = await getEntryTerms("posts", post.data.id, "tag");
    return { post, tags };
  })
);

const featured = postsWithTags[0];
const rest = postsWithTags.slice(1);
const POSTS_PER_PAGE = 9; // featured counts as 1, so total first view = 10

const formatDate = (date: Date) =>
  date.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<BaseLayout
  title="El Diario | Carmen Viamonte"
  description="Blog de psicología y psicoanálisis de Carmen Viamonte. Reflexiones sobre salud mental, relaciones y bienestar."
>
  <Navbar />

  <!-- Header -->
  <header class="pt-20 md:pt-28 pb-12 md:pb-16 px-6 lg:px-12 max-w-7xl mx-auto" style="border-bottom: 1px solid rgba(85,53,39,0.12)">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <span class="text-forest font-bold uppercase tracking-widest text-xs mb-3 block">Reflexiones</span>
        <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-bold text-main tracking-tight">El Diario.</h1>
      </div>
      <p class="text-sm md:text-base text-muted font-light leading-relaxed max-w-xs md:text-right pb-1">
        Psicología, psicoanálisis y el arte de vivir conscientemente.
      </p>
    </div>
  </header>

  {postsWithTags.length === 0 ? (
    <div class="text-center py-32 px-6">
      <p class="text-muted font-light text-lg mb-8">Aún no hay artículos publicados.</p>
      <a href="/_emdash/admin/content/posts/new"
        class="inline-flex items-center gap-2 bg-forest text-[#EEE5DB] px-6 py-3 rounded-full font-bold text-sm hover:bg-forest/90 transition-all">
        Crear el primer artículo
      </a>
    </div>
  ) : (
    <main class="max-w-7xl mx-auto px-6 lg:px-12">

      {/* ── DESTACADO ── */}
      {featured && (
        <article class="featured-article">
          <a href={`/posts/${featured.post.id}`} class="featured-link">

            <!-- Imagen -->
            <div class="featured-img-wrap">
              {featured.post.data.featured_image ? (
                <img
                  src={`/_emdash/api/media/file/${featured.post.data.featured_image}`}
                  alt={featured.post.data.title ?? ""}
                  class="featured-img-inner"
                />
              ) : (
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                  <span style="font-family:'Parkinsans',sans-serif;font-size:3rem;font-weight:700;color:rgba(85,53,39,0.1)">CV</span>
                </div>
              )}
            </div>

            <!-- Texto -->
            <div class="featured-body">
              <div class="featured-meta">
                <span class="featured-tag">Destacado</span>
                {featured.tags.length > 0 && (
                  <>
                    <span class="meta-sep"></span>
                    <span class="featured-tag">{featured.tags[0].label}</span>
                  </>
                )}
                {featured.post.data.publishedAt && (
                  <>
                    <span class="meta-sep"></span>
                    <time class="featured-date">{formatDate(featured.post.data.publishedAt)}</time>
                  </>
                )}
              </div>

              <h2 class="featured-title">
                {featured.post.data.title}
              </h2>

              {featured.post.data.excerpt && (
                <p class="featured-excerpt">
                  {featured.post.data.excerpt}
                </p>
              )}

              <span class="featured-cta">
                Leer artículo
                <i data-lucide="arrow-right" style="width:14px;height:14px;display:inline-block"></i>
              </span>
            </div>

          </a>
        </article>
      )}

      {/* ── LISTA ── */}
      {rest.length > 0 && (
        <div id="posts-list">
          {rest.map(({ post, tags }, i) => (
            <article
              class="post-row group"
              data-index={i}
              style={i >= POSTS_PER_PAGE ? "display:none" : ""}
            >
              <a href={`/posts/${post.id}`} class="post-row-link">

                <span class="post-number font-display font-bold select-none" style="color:rgba(85,53,39,0.08); line-height:1">
                  {String(i + 2).padStart(2, "0")}
                </span>

                <div class="post-thumb" style="border-radius: 0.875rem; overflow:hidden; background:rgba(85,53,39,0.05); flex-shrink:0">
                  {post.data.featured_image ? (
                    <img
                      src={`/_emdash/api/media/file/${post.data.featured_image}`}
                      alt={post.data.title ?? ""}
                      style="width:100%; height:100%; object-fit:cover; transition:transform 0.5s ease"
                      class="post-thumb-img"
                    />
                  ) : (
                    <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center;">
                      <span class="font-display font-bold" style="font-size:1.25rem; color:rgba(85,53,39,0.12)">CV</span>
                    </div>
                  )}
                </div>

                <div style="flex:1; min-width:0">
                  <div style="display:flex; align-items:center; gap:0.625rem; margin-bottom:0.5rem; flex-wrap:wrap">
                    {tags.length > 0 && (
                      <span style="font-size:10px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#4A8A57">{tags[0].label}</span>
                    )}
                    {tags.length > 0 && post.data.publishedAt && (
                      <span style="width:1px; height:10px; background:rgba(85,53,39,0.2); display:inline-block"></span>
                    )}
                    {post.data.publishedAt && (
                      <time style="font-size:10px; font-weight:500; color:#7A6256; letter-spacing:0.04em">{formatDate(post.data.publishedAt)}</time>
                    )}
                  </div>

                  <h2 class="post-title font-display font-bold text-main" style="line-height:1.25; letter-spacing:-0.01em; margin-bottom:0.375rem; transition: color 0.3s ease">
                    {post.data.title}
                  </h2>

                  {post.data.excerpt && (
                    <p class="text-muted font-light leading-relaxed post-excerpt" style="font-size:0.875rem">
                      {post.data.excerpt}
                    </p>
                  )}
                </div>

                <div class="post-arrow" style="flex-shrink:0; opacity:0; transition: opacity 0.3s, transform 0.3s; transform: translateX(-8px)">
                  <i data-lucide="arrow-right" style="width:18px; height:18px; color:#553527"></i>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}

      {/* ── VER MÁS ── */}
      {rest.length > POSTS_PER_PAGE && (
        <div id="load-more-wrap" class="text-center py-14">
          <button id="load-more-btn"
            class="inline-flex items-center gap-3 border border-main/30 text-main font-semibold text-sm px-8 py-3.5 rounded-full hover:bg-main hover:text-[#EEE5DB] transition-all duration-300">
            Ver más artículos
            <i data-lucide="chevron-down" class="w-4 h-4"></i>
          </button>
          <p id="load-more-count" class="text-muted text-xs font-medium mt-3" style="letter-spacing:0.05em">
            Mostrando {Math.min(POSTS_PER_PAGE, rest.length)} de {rest.length} artículos
          </p>
        </div>
      )}

    </main>
  )}

  <div style="padding-bottom: 6rem"></div>
  <Footer />
  <ContactModal />
</BaseLayout>

<style>
  /* ── Featured ── */
  .featured-article {
    padding: 3.5rem 0;
    border-bottom: 1px solid rgba(85,53,39,0.12);
  }
  .featured-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    text-decoration: none;
    color: inherit;
  }
  @media (min-width: 768px) {
    .featured-link {
      grid-template-columns: 460px 1fr;
      gap: 3.5rem;
      align-items: center;
    }
  }
  @media (min-width: 1024px) {
    .featured-link {
      grid-template-columns: 520px 1fr;
      gap: 5rem;
    }
  }
  .featured-img-wrap {
    width: 100%;
    height: 300px;
    border-radius: 1.5rem;
    overflow: hidden;
    background: rgba(85,53,39,0.05);
  }
  @media (min-width: 768px) {
    .featured-img-wrap {
      height: 360px;
    }
  }
  @media (min-width: 1024px) {
    .featured-img-wrap {
      height: 400px;
    }
  }
  .featured-img-inner {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
    display: block;
  }
  .featured-link:hover .featured-img-inner {
    transform: scale(1.04);
  }
  .featured-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .featured-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #4A8A57;
  }
  .meta-sep {
    display: inline-block;
    width: 1px;
    height: 12px;
    background: rgba(85,53,39,0.2);
  }
  .featured-date {
    font-size: 10px;
    font-weight: 500;
    color: #7A6256;
    letter-spacing: 0.05em;
  }
  .featured-title {
    font-family: 'Parkinsans', sans-serif;
    font-size: clamp(1.875rem, 3.5vw, 3rem);
    font-weight: 700;
    color: #553527;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
    transition: color 0.4s ease;
  }
  .featured-link:hover .featured-title {
    color: #7A6256;
  }
  .featured-excerpt {
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    color: #7A6256;
    font-weight: 300;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 34rem;
  }
  .featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #553527;
    border-bottom: 1px solid #553527;
    padding-bottom: 2px;
    transition: color 0.3s, border-color 0.3s;
    width: fit-content;
  }
  .featured-link:hover .featured-cta {
    color: #4A8A57;
    border-color: #4A8A57;
  }

  /* Post row */
  .post-row {
    border-bottom: 1px solid rgba(85,53,39,0.12);
  }
  .post-row:last-child {
    border-bottom: none;
  }
  .post-row-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.75rem 0;
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .post-row-link {
      gap: 2rem;
      padding: 2rem 0;
    }
  }
  .post-number {
    display: none;
    font-size: 2.5rem;
    width: 3rem;
    text-align: right;
  }
  @media (min-width: 768px) {
    .post-number {
      display: block;
    }
  }
  .post-thumb {
    width: 88px;
    height: 88px;
  }
  @media (min-width: 768px) {
    .post-thumb {
      width: 112px;
      height: 112px;
    }
  }
  .post-title {
    font-size: clamp(1rem, 1.8vw, 1.25rem);
  }
  @media (min-width: 1024px) {
    .post-title {
      font-size: 1.25rem;
    }
  }
  .post-excerpt {
    display: none;
  }
  @media (min-width: 640px) {
    .post-excerpt {
      display: block;
    }
  }
  .post-arrow {
    display: none;
  }
  @media (min-width: 1024px) {
    .post-arrow {
      display: flex;
    }
  }
  .post-row:hover .post-thumb-img {
    transform: scale(1.06);
  }
  .post-row:hover .post-title {
    color: #7A6256;
  }
  .post-row:hover .post-arrow {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }
</style>

<script>
  const BATCH = 9;
  let shown = BATCH;

  const btn = document.getElementById("load-more-btn");
  const countEl = document.getElementById("load-more-count");
  const wrap = document.getElementById("load-more-wrap");
  const rows = document.querySelectorAll<HTMLElement>(".post-row");

  function updateCount() {
    if (!countEl) return;
    const total = rows.length;
    const visible = Math.min(shown, total);
    countEl.textContent = `Mostrando ${visible} de ${total} artículos`;
  }

  btn?.addEventListener("click", () => {
    const next = shown + BATCH;
    rows.forEach((row) => {
      const idx = parseInt(row.dataset.index ?? "0");
      if (idx >= shown && idx < next) {
        row.style.display = "";
        // small fade-in
        row.style.opacity = "0";
        requestAnimationFrame(() => {
          row.style.transition = "opacity 0.4s ease";
          row.style.opacity = "1";
        });
      }
    });
    shown = next;
    updateCount();
    if (shown >= rows.length && wrap) {
      wrap.style.display = "none";
    }
  });
</script>
